{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Storage Agent Workbench",
  "version": "0.19.12",
  "identifier": "com.storageagent.workbench",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Storage Agent Workbench",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Object storage agent: ops, analytics, management",
    "longDescription": "Local-first agent for object storage on S3-compatible systems \u2014 operations, analytics, and management: diagnostics, access-log and inventory analysis, account and bucket configuration review, error triage, usage/cost profiling, and optimization.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "sidecar-dist/storage-agent-sidecar": "sidecar/"
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
