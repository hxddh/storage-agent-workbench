{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the Phase 08 shell: core + spawning the bundled sidecar only.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/storage-agent-sidecar",
          "sidecar": true,
          "args": [
            "--host",
            "127.0.0.1",
            "--port",
            { "validator": "\\d+" }
          ]
        }
      ]
    }
  ]
}
